{
  "name": "tv-tracker",
  "private": true,
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build && mkdir -p build/server/generated/prisma && cp -r app/generated/prisma build/server/generated/",
    "delete:episode": "tsx scripts/delete-episode.ts",
    "delete:season": "tsx scripts/delete-season.ts",
    "delete:episode:id": "tsx scripts/delete-episode-by-id.ts",
    "delete:episode-link": "tsx scripts/remove-inexistent-episode-links.ts",
    "dev": "react-router dev",
    "dev:host": "react-router dev --host",
    "dev:deps": "docker compose -f docker-compose.dev.yml up -d",
    "dev:deps:stop": "docker compose -f docker-compose.dev.yml stop",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "postinstall": "prisma generate",
    "setup": "prisma generate && prisma db push && prisma db seed",
    "start": "react-router-serve ./build/server/index.js",
    "test": "SESSION_SECRET=secret vitest",
    "test:e2e": "pnpm run test:e2e:setup && pnpm run test:e2e:run && pnpm run test:e2e:teardown",
    "test:e2e:report": "playwright show-report",
    "test:e2e:run": "node --env-file=.env.e2e ./node_modules/playwright/cli.js test",
    "test:e2e:setup": "docker compose -f docker-compose.e2e.yml up -d && sh -c 'for i in $(seq 1 30); do if node --env-file=.env.e2e ./node_modules/prisma/build/index.js db push --accept-data-loss 2>/dev/null; then break; fi; echo \"Waiting for PostgreSQL ($i/30)...\"; sleep 2; done' && node --env-file=.env.e2e ./node_modules/prisma/build/index.js db seed",
    "test:e2e:teardown": "docker compose -f docker-compose.e2e.yml down -v",
    "typecheck": "tsc -b",
    "update:episode:force": "tsx scripts/force-episode-update.ts",
    "update:mazeId": "tsx scripts/update-maze-id.ts",
    "update:episodes": "tsx scripts/get-new-episodes.ts",
    "update:episodes:info": "tsx scripts/update-episodes.ts",
    "update:show:status": "tsx scripts/update-show-status.ts",
    "validate": "pnpm run test -- --run && pnpm run lint && pnpm run typecheck && pnpm run test:e2e"
  },
  "prettier": {
    "trailingComma": "es5"
  },
  "dependencies": {
    "@flipt-io/flipt": "^1.5.0",
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.13.1",
    "@sentry/cli": "^3.3.3",
    "@sentry/node": "^10.46.0",
    "@sentry/react-router": "^10.46.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "entities": "^8.0.0",
    "isbot": "^5.1.36",
    "nodemailer": "^8.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "recharts": "^3.8.0",
    "striptags": "^3.2.0",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@react-router/dev": "^7.13.1",
    "@react-router/fs-routes": "^7.13.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.3",
    "vitest": "4.1.0",
    "vitest-browser-react": "^2.1.0",
    "vitest-mock-extended": "^3.1.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@react-router/dev>vite": "8"
      }
    }
  },
  "packageManager": "pnpm@10.32.1",
  "version": "2.0.0"
}
